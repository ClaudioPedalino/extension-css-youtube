{
    "manifest_version": 3,
    "name": "YouTube ish effect",
    "version": "1.0.3",
    "description": "Darkens YouTube UI and makes video thumbnails pop with color on hover.",
    "permissions": [],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_start"
        }
    ]
}